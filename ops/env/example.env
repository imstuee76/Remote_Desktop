# Broker bind and public URLs
BROKER_BIND=0.0.0.0:8080
PUBLIC_BASE_URL=https://broker.example.com
RELAY_PUBLIC_URL=https://relay.example.com

# Domain / DNS
BROKER_DOMAIN=broker.example.com
RELAY_DOMAIN=relay.example.com
STATUS_DOMAIN=status.example.com

# Optional provider status feed
VENTRAIP_STATUS_API=https://status.ventraip.com.au/api/v1/status

# Future auth / pairing
OWNER_BOOTSTRAP_TOKEN=replace-me
PAIRING_CODE_TTL_SECONDS=300

# Admin / update controls
BROKER_ADMIN_TOKEN=replace-me
PRIVATE_REMOTE_WORKSPACE_ROOT=/opt/private-remote
PRIVATE_REMOTE_HOST_SERVICE=private-remote-hostd
PRIVATE_REMOTE_BROKER_SERVICE=private-remote-broker
PRIVATE_REMOTE_BROKER_RESTART_MODE=systemd
